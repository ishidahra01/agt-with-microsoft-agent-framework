CLAUDE_CODE_USE_FOUNDRY=1

# Set one of the following. BASE_URL takes precedence if both are set.
# ANTHROPIC_FOUNDRY_RESOURCE=<your-foundry-resource-name>
ANTHROPIC_FOUNDRY_BASE_URL=<your-foundry-base-url>

# Optional. When set, Claude Code uses API key authentication.
# Leave unset for Entra ID authentication via Azure CLI, managed identity, or other DefaultAzureCredential sources.
ANTHROPIC_FOUNDRY_API_KEY=<your-foundry-api-key>

# Pin deployment names to avoid alias drift when Anthropic updates model aliases.
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

CLAUDE_MODEL=sonnet
CLAUDE_MAX_TURNS=12
CLAUDE_EFFORT=medium
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_CODE_USE_POWERSHELL_TOOL=1

# Langfuse tracing
CLAUDE_CODE_ENABLE_TELEMETRY=1
CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
APP_ENABLE_PYTHON_TRACING=1

OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://us.cloud.langfuse.com/api/public/otel
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://us.cloud.langfuse.com/api/public/otel/v1/traces
LANGFUSE_PUBLIC_KEY=<your-langfuse-public-key>
LANGFUSE_SECRET_KEY=<your-langfuse-secret-key>
LANGFUSE_OTLP_INGESTION_VERSION=4

OTEL_SERVICE_NAME=governed-workspace-demo
OTEL_RESOURCE_ATTRIBUTES=service.version=dev,deployment.environment=local
OTEL_TRACES_EXPORT_INTERVAL=1000

# Optional runtime settings
PORT=8088
LOG_LEVEL=INFO